# ── Jira ──────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://<org>.atlassian.net
JIRA_EMAIL
JIRA_API_TOKEN=
JIRA_PROJECT_KEYS=CAPI,PLAT,BUG
# Nome exato do projeto de bugs (usado para flag is_bug)
JIRA_BUG_PROJECT_NAME=Capi Bugs

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=
# Repos no formato org/repo, separados por vírgula
GITHUB_REPOS=<org>/capi-backend, <org>/capi-frontend

# ── Banco de dados ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://capi:capi@localhost:5433/bi

# ── Comportamento do ETL ──────────────────────────────────────────────────────
# Janela de lookback para o modo incremental (dias)
ETL_SINCE_DAYS=7
# Nível de log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
